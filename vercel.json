{
  "framework": null,
  "outputDirectory": ".",
  "trailingSlash": false,
  "headers": [
    { "source": "/assets/img/(.*)",   "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }] },
    { "source": "/assets/video/(.*)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }] }
  ]
}
